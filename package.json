{
  "name": "ms2board",
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup:fetch": "cd packages/build && bun run src/fetch_data.ts",
    "setup:extract": "cd packages/build && bun run src/extract_data.ts",
    "setup:indexes": "bun run --cwd packages/server ensure-indexes",
    "dev:server": "bun run --cwd packages/server dev",
    "dev:web": "bun run --cwd packages/web dev",
    "test:server": "bun run --cwd packages/server test",
    "test:web": "bun run --cwd packages/web test",
    "prettier": "prettier . --write",
    "eslint": "eslint ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1"
  },
  "private": true
}
